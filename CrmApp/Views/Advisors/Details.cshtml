@model Advisor

<h1>Detail poradce</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.FirstName)</dt>
        <dd class="col-sm-10">@Model.FirstName</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.LastName)</dt>
        <dd class="col-sm-10">@Model.LastName</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.BirthNumber)</dt>
        <dd class="col-sm-10">@Model.BirthNumber</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Age)</dt>
        <dd class="col-sm-10">@Model.Age</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Email)</dt>
        <dd class="col-sm-10">@(Model.Email ?? "—")</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Phone)</dt>
        <dd class="col-sm-10">@(Model.Phone ?? "—")</dd>
    </dl>
</div>

<h3 class="mt-4 text-primary">Spravované smlouvy (Správce)</h3>
@if (Model.ManagedContracts != null && Model.ManagedContracts.Any())
{
    <table class="table table-hover shadow-sm mb-4">
        <thead class="table-primary">
            <tr>
                <th>Evidenční číslo</th>
                <th>Instituce</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var contract in Model.ManagedContracts)
            {
                <tr>
                    <td>@contract.RegistrationNumber</td>
                    <td>@contract.Institution</td>
                    <td class="text-end">
                        <a asp-controller="Contracts" asp-action="Details" asp-route-id="@contract.Id" class="btn btn-sm btn-outline-primary">Detail smlouvy</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted mb-4">Tento poradce aktuálně nespravuje žádné smlouvy.</p>
}

<h3 class="mt-4 text-secondary">Účast na smlouvách (Účastník)</h3>
@if (Model.ParticipatedContracts != null && Model.ParticipatedContracts.Any())
{
    <table class="table table-hover shadow-sm">
        <thead class="table-secondary">
            <tr>
                <th>Evidenční číslo</th>
                <th>Instituce</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var contract in Model.ParticipatedContracts)
            {
                <tr>
                    <td>@contract.RegistrationNumber</td>
                    <td>@contract.Institution</td>
                    <td class="text-end">
                        <a asp-controller="Contracts" asp-action="Details" asp-route-id="@contract.Id" class="btn btn-sm btn-outline-secondary">Detail smlouvy</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Tento poradce nefiguruje jako účastník na žádné smlouvě.</p>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Upravit</a>
    <a asp-action="Index" class="btn btn-secondary">Zpět</a>
</div>