@model CrmApp.Models.ViewModels.AdvisorIndexViewModel

<h1>Poradci</h1>

<form method="get" class="row g-2 mb-4 align-items-center">
    <div class="col-auto">
        <input asp-for="Query.Search" class="form-control" placeholder="Hledat jméno, RČ..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Filtrovat</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Zrušit</a>
    </div>
</form>

<a asp-action="Create" class="btn btn-primary mb-3">Přidat poradce</a>

<table class="table">
    <thead>
        <tr>
            <th>
                <a asp-action="Index"
                   asp-route-search="@Model.Query.Search"
                   asp-route-sortBy="@(Model.Query.SortBy == "firstName" ? "firstNameDesc" : "firstName")"
                   class="text-decoration-none text-dark sort-link">
                    Jméno
                    @(Model.Query.SortBy == "firstName" ? "▲" : Model.Query.SortBy == "firstNameDesc" ? "▼" : "")
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-search="@Model.Query.Search"
                   asp-route-sortBy="@(Model.Query.SortBy == "lastName" ? "lastNameDesc" : "lastName")"
                   class="text-decoration-none text-dark sort-link">
                    Příjmení
                    @(Model.Query.SortBy == "lastName" ? "▲" : Model.Query.SortBy == "lastNameDesc" ? "▼" : "")
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-search="@Model.Query.Search"
                   asp-route-sortBy="@(Model.Query.SortBy == "birthNumber" ? "birthNumberDesc" : "birthNumber")"
                   class="text-decoration-none text-dark sort-link">
                    Rodné číslo
                    @(Model.Query.SortBy == "birthNumber" ? "▲" : Model.Query.SortBy == "birthNumberDesc" ? "▼" : "")
                </a>
            </th>
            <th>Věk</th>
            <th>E-mail</th>
            <th>Telefon</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Advisors.Any())
        {
            var hasFilters = !string.IsNullOrWhiteSpace(Model.Query.Search);

            <tr>
                <td colspan="7" class="text-center text-muted py-4">
                    @(hasFilters ? "Zadaným filtrům neodpovídají žádní poradci." : "Zatím nejsou uloženi žádní poradci.")
                </td>
            </tr>
        }
        else
        {
            @foreach (var advisor in Model.Advisors)
            {
                <tr>
                    <td>@advisor.FirstName</td>
                    <td>@advisor.LastName</td>
                    <td>@advisor.BirthNumber</td>
                    <td>@advisor.Age</td>
                    <td>@(advisor.Email ?? "—")</td>
                    <td>@(advisor.Phone ?? "—")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@advisor.Id">Detail</a>
                        <a asp-action="Edit" asp-route-id="@advisor.Id">Upravit</a>
                        <button type="button"
                                class="btn btn-danger btn-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal"
                                data-id="@advisor.Id"
                                data-contracts="@(advisor.ManagedContracts?.Count ?? 0)">
                            Smazat
                        </button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Potvrdit smazání</h5>
            </div>
            <form method="post" asp-action="Delete">
                <div class="modal-body">
                    <p>Opravdu chcete smazat tohoto poradce?</p>

                    <div id="contractsWarning" class="alert alert-warning d-none">
                        <strong>Pozor!</strong> Tento poradce spravuje <span id="contractsCount">0</span> smluv.
                        Pokud ho smažete, musíte s ním smazat i tyto smlouvy.

                        <div class="form-check mt-3">
                            <input class="form-check-input" type="checkbox" id="deleteContracts" name="deleteContracts" value="true">
                            <label class="form-check-label text-danger fw-bold" for="deleteContracts">
                                Rozumím a chci nenávratně smazat i tyto smlouvy
                            </label>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zrušit</button>
                    <input type="hidden" id="deleteId" name="id" />
                    <button type="submit" id="confirmDeleteBtn" class="btn btn-danger">Smazat</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('#deleteModal').on('show.bs.modal', function (e) {
            const $button = $(e.relatedTarget);
            const advisorId = $button.data('id');
            const contractsCount = parseInt($button.data('contracts')) || 0;

            $('#deleteId').val(advisorId);

            const $warningDiv = $('#contractsWarning');
            const $checkbox = $('#deleteContracts');
            const $submitBtn = $('#confirmDeleteBtn');

            $checkbox.prop('checked', false);

            if (contractsCount > 0) {
                $warningDiv.removeClass('d-none');
                $('#contractsCount').text(contractsCount);
                $submitBtn.prop('disabled', true);

                $checkbox.off('change').on('change', function () {
                    $submitBtn.prop('disabled', !$(this).is(':checked'));
                });
            } else {
                $warningDiv.addClass('d-none');
                $submitBtn.prop('disabled', false);
            }
        });
    </script>
}