@model CrmApp.Models.ViewModels.ContractIndexViewModel

<h1>Smlouvy</h1>

<form method="get" class="row g-2 mb-4 align-items-center">
    <div class="col-auto">
        <input asp-for="Query.Search" class="form-control" placeholder="Hledat evidenční číslo, instituci..." />
    </div>
    <div class="col-auto form-check ms-3 mt-3">
        <input asp-for="Query.HideInactive" class="form-check-input" />
        <label asp-for="Query.HideInactive" class="form-check-label">Skrýt neaktivní (vypršelé)</label>
    </div>
    <div class="col-auto ms-2">
        <button type="submit" class="btn btn-primary">Filtrovat</button>
        <button type="submit" asp-action="ExportCsv" class="btn btn-success ms-2">Export do CSV</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Zrušit</a>
    </div>
</form>

<a asp-action="Create" class="btn btn-primary mb-3">Přidat smlouvu</a>

<table class="table">
    <thead>
        <tr>
            <th>
                <a asp-action="Index"
                   asp-route-search="@Model.Query.Search"
                   asp-route-hideInactive="@Model.Query.HideInactive"
                   asp-route-sortBy="@(Model.Query.SortBy == "registrationNumber" ? "registrationNumberDesc" : "registrationNumber")"
                   class="text-decoration-none text-dark sort-link">
                    Evidenční číslo
                    @(Model.Query.SortBy == "registrationNumber" ? "▲" : Model.Query.SortBy == "registrationNumberDesc" ? "▼" : "")
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-search="@Model.Query.Search"
                   asp-route-hideInactive="@Model.Query.HideInactive"
                   asp-route-sortBy="@(Model.Query.SortBy == "institution" ? "institutionDesc" : "institution")"
                   class="text-decoration-none text-dark sort-link">
                    Instituce
                    @(Model.Query.SortBy == "institution" ? "▲" : Model.Query.SortBy == "institutionDesc" ? "▼" : "")
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-search="@Model.Query.Search"
                   asp-route-hideInactive="@Model.Query.HideInactive"
                   asp-route-sortBy="@(Model.Query.SortBy == "client" ? "clientDesc" : "client")"
                   class="text-decoration-none text-dark sort-link">
                    Klient
                    @(Model.Query.SortBy == "client" ? "▲" : Model.Query.SortBy == "clientDesc" ? "▼" : "")
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-search="@Model.Query.Search"
                   asp-route-hideInactive="@Model.Query.HideInactive"
                   asp-route-sortBy="@(Model.Query.SortBy == "manager" ? "managerDesc" : "manager")"
                   class="text-decoration-none text-dark sort-link">
                    Správce
                    @(Model.Query.SortBy == "manager" ? "▲" : Model.Query.SortBy == "managerDesc" ? "▼" : "")
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-search="@Model.Query.Search"
                   asp-route-hideInactive="@Model.Query.HideInactive"
                   asp-route-sortBy="@(Model.Query.SortBy == "signedDate" ? "signedDateDesc" : "signedDate")"
                   class="text-decoration-none text-dark sort-link">
                    Datum uzavření
                    @(Model.Query.SortBy == "signedDate" ? "▲" : Model.Query.SortBy == "signedDateDesc" ? "▼" : "")
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-search="@Model.Query.Search"
                   asp-route-hideInactive="@Model.Query.HideInactive"
                   asp-route-sortBy="@(Model.Query.SortBy == "effectiveDate" ? "effectiveDateDesc" : "effectiveDate")"
                   class="text-decoration-none text-dark sort-link">
                    Platnost od
                    @(Model.Query.SortBy == "effectiveDate" ? "▲" : Model.Query.SortBy == "effectiveDateDesc" ? "▼" : "")
                </a>
            </th>
            <th>
                <a asp-action="Index"
                   asp-route-search="@Model.Query.Search"
                   asp-route-hideInactive="@Model.Query.HideInactive"
                   asp-route-sortBy="@(Model.Query.SortBy == "endDate" ? "endDateDesc" : "endDate")"
                   class="text-decoration-none text-dark sort-link">
                    Datum ukončení
                    @(Model.Query.SortBy == "endDate" ? "▲" : Model.Query.SortBy == "endDateDesc" ? "▼" : "")
                </a>
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Contracts.Any())
        {
            var hasFilters = !string.IsNullOrWhiteSpace(Model.Query.Search) || Model.Query.HideInactive;

            <tr>
                <td colspan="8" class="text-center text-muted py-4">
                    @if (hasFilters)
                    {
                        <span>Zadaným filtrům neodpovídají žádné smlouvy.</span>
                    }
                    else
                    {
                        <span>Zatím nejsou uloženy žádné smlouvy.</span>
                    }
                </td>
            </tr>
        }
        else
        {
            @foreach (var contract in Model.Contracts)
            {
                <tr>
                    <td>@contract.RegistrationNumber</td>
                    <td>@contract.Institution</td>
                    <td>@(contract.Client?.FirstName) @(contract.Client?.LastName)</td>
                    <td>@(contract.Manager?.FirstName) @(contract.Manager?.LastName)</td>
                    <td>@contract.SignedDate.ToShortDateString()</td>
                    <td>@contract.EffectiveDate.ToShortDateString()</td>
                    <td>@(contract.EndDate.HasValue ? contract.EndDate.Value.ToShortDateString() : "—")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@contract.Id">Detail</a>
                        <a asp-action="Edit" asp-route-id="@contract.Id">Upravit</a>
                        <button type="button"
                                class="btn btn-danger btn-sm"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal"
                                data-id="@contract.Id">
                            Smazat
                        </button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Potvrdit smazání</h5>
            </div>
            <div class="modal-body">Opravdu chcete smazat tuto smlouvu?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zrušit</button>
                <form method="post" asp-action="Delete">
                    <input type="hidden" id="deleteId" name="id" />
                    <button type="submit" class="btn btn-danger">Smazat</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('#deleteModal').on('show.bs.modal', function (e) {
            const $button = $(e.relatedTarget);
            const contractId = $button.data('id');
            $('#deleteId').val(contractId);
        });
    </script>
}